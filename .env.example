# ── Base de données principale ────────────────────────────────────────────────
DB_TYPE=mysql
DB_HOST=host.docker.internal
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
MYSQL_ROOT_PASSWORD=your_mysql_root_password

# ── Clés API ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
CROQ=your_groq_api_key

# ── Auth MySQL ────────────────────────────────────────────────────────────────
AUTH_DB_HOST=mysql-auth
AUTH_DB_PORT=3306
AUTH_DB_USER=askdata
AUTH_DB_PASSWORD=your_auth_db_password
AUTH_DB_ROOT_PASSWORD=your_auth_db_root_password
AUTH_DB_NAME=askdata_auth

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRE_SECONDS=28800

# ── Compte admin initial ──────────────────────────────────────────────────────
ADMIN_EMAIL=admin@askdata.local
ADMIN_PASSWORD=ChangeMe1234!

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_ORIGIN=https://localhost:3000
